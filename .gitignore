# ============================================================
# DataInsight API — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Distribution / Packaging ---
build/
dist/
*.egg-info/
.eggs/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Environment variables (secrets) ---
.env
*.env

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Uploaded data files (runtime-generated) ---
uploads/
plots/
reports/

# --- Logs ---
*.log
logs/

# --- MyPy / type checking ---
.mypy_cache/
.dmypy.json

# --- Jupyter Notebooks ---
.ipynb_checkpoints/

# --- Docker ---
*.tar
