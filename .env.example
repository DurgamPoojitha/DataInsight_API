# ============================================================
# DataInsight API — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# --- Application ---
APP_NAME="DataInsight API"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=1

# --- CORS (comma-separated origins, use * for development) ---
CORS_ORIGINS=*

# --- File Storage ---
UPLOAD_DIR=uploads
PLOTS_DIR=plots
REPORTS_DIR=reports
MAX_UPLOAD_SIZE_MB=50

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
